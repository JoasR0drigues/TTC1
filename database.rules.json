{
  "rules": {
    ".read": false,
    ".write": false,

    "usuarios_sistema": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "usuarios": {
      "$uidTag": {
        ".read": "auth != null && data.child('vinculado_ao_usuario').val() === auth.uid",
        ".write": "auth != null && ((!data.exists() && newData.child('vinculado_ao_usuario').val() === auth.uid) || (data.exists() && data.child('vinculado_ao_usuario').val() === auth.uid))"
      }
    },

    "patrimonios": {
      "$patrimonioId": {
        ".read": "auth != null && data.child('usuario_uid').val() === auth.uid",
        ".write": "auth != null && ((!data.exists() && newData.child('usuario_uid').val() === auth.uid) || (data.exists() && data.child('usuario_uid').val() === auth.uid))"
      }
    },

    "tags_patrimonio": {
      "$uidTag": {
        ".read": "auth != null && data.child('vinculado_ao_usuario').val() === auth.uid",
        ".write": "auth != null && ((!data.exists() && newData.child('vinculado_ao_usuario').val() === auth.uid) || (data.exists() && data.child('vinculado_ao_usuario').val() === auth.uid))"
      }
    },

    "movimentacoes": {
      "$movId": {
        ".read": "auth != null && data.child('usuario_uid').val() === auth.uid",
        ".write": "auth != null && ((!data.exists() && newData.child('usuario_uid').val() === auth.uid) || (data.exists() && data.child('usuario_uid').val() === auth.uid))"
      }
    },

    "salas": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "salas_patrimonios": {
      "$uid": {
        "$salaId": {
          "$patrimonioId": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },

    "monitoramento_ultrassonico": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "configuracoes": {
          "$patrimonioId": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },

    "leituras_recentes": {
      ".indexOn": ["timestamp"],
      "$leituraId": {
        ".read": "auth != null && data.child('usuario_uid').val() === auth.uid",
        ".write": "auth != null && newData.child('usuario_uid').val() === auth.uid"
      }
    },

    "acessos": {
      "$acessoId": {
        ".read": "auth != null && data.child('usuario_uid').val() === auth.uid",
        ".write": "auth != null && newData.child('usuario_uid').val() === auth.uid"
      }
    },

    "teste_conexao": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}